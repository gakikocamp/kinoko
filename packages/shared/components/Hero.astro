---
import type { StoreInfo } from "../lib/site";
import { withBase } from "../lib/url";

interface Props {
  store: StoreInfo;
}
const { store } = Astro.props;
---

<section class="hero">
  <!-- 動く光の背景（控えめに） -->
  <div class="hero__aurora" aria-hidden="true">
    <span class="blob blob--teal"></span>
    <span class="blob blob--gold"></span>
  </div>

  <!-- 縦組みのサイドラベル -->
  <span class="hero__side en" aria-hidden="true">Fukuoka — Est.</span>

  <div class="container container--wide hero__grid">
    <div class="hero__copy">
      <p class="hero__kicker en">Anela Cafe Fukuoka — {store.shortName}</p>

      <h1 class="hero__title">
        <span class="reveal-line" style="--reveal-delay:0.05s"
          ><span>{store.tagline}</span></span
        >
      </h1>

      <p class="hero__sub en">Coffee, rescue dogs, and gentle time.</p>

      <p class="hero__lead">
        コーヒーと、保護犬と、やさしい時間。<br />
        アネラカフェ{store.shortName}へようこそ。
      </p>

      <div class="hero__actions">
        <a class="btn btn--primary" href={withBase("/access")}>アクセス・営業時間</a>
        <a class="arrow-link" href={store.instagram} target="_blank" rel="noopener">
          <span class="arrow-link__line"></span>Instagram を見る
        </a>
      </div>
    </div>

    <div class="hero__media" data-parallax>
      <span class="hero__halo" aria-hidden="true"></span>
      <span class="hero__frame" aria-hidden="true"></span>
      {
        store.heroImage ? (
          <img
            class="hero__img"
            src={store.heroImage}
            alt={`アネラカフェ${store.shortName}の店内・わんこの様子`}
            width="640"
            height="800"
          />
        ) : (
          <div class="ph hero__ph" role="img" aria-label="店内・保護犬の写真（準備中）">
            店内・わんこの写真
          </div>
        )
      }
      <span class="hero__caption en">No. 01 — Ohori &amp; Harada</span>
    </div>
  </div>

  <a class="hero__scroll en" href="#main-start" aria-label="下へスクロール">
    Scroll<span class="hero__scroll-line" aria-hidden="true"></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: min(92vh, 880px);
    display: flex;
    align-items: center;
    padding-block: clamp(72px, 12vh, 140px);
  }

  /* ---- 動く光 ---- */
  .hero__aurora {
    position: absolute;
    inset: -20% -10% 0;
    z-index: -2;
    filter: blur(70px);
    opacity: 0.55;
  }
  .blob {
    position: absolute;
    width: 46vw;
    max-width: 600px;
    aspect-ratio: 1;
    border-radius: 50%;
    mix-blend-mode: multiply;
  }
  .blob--teal {
    top: -10%;
    right: -6%;
    background: radial-gradient(circle at 30% 30%, var(--brown), transparent 64%);
    animation: drift1 22s ease-in-out infinite;
  }
  .blob--gold {
    bottom: -12%;
    left: -8%;
    background: radial-gradient(circle at 30% 30%, var(--gold), transparent 64%);
    animation: drift2 26s ease-in-out infinite;
  }
  @keyframes drift1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-5%, 7%) scale(1.1); }
  }
  @keyframes drift2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(7%, -5%) scale(1.08); }
  }

  /* ---- 縦サイドラベル ---- */
  .hero__side {
    position: absolute;
    left: clamp(14px, 2vw, 30px);
    top: 50%;
    transform: translateY(-50%);
    writing-mode: vertical-rl;
    font-style: italic;
    letter-spacing: 0.28em;
    font-size: 0.78rem;
    color: color-mix(in srgb, var(--brown-deep) 60%, transparent);
    z-index: 1;
  }
  @media (max-width: 980px) {
    .hero__side { display: none; }
  }

  /* ---- グリッド ---- */
  .hero__grid {
    position: relative;
    display: grid;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
    width: 100%;
  }
  @media (min-width: 920px) {
    .hero__grid {
      grid-template-columns: 1.06fr 0.94fr;
    }
  }

  .hero__kicker {
    font-style: italic;
    font-size: 0.9rem;
    letter-spacing: 0.14em;
    color: var(--gold-deep);
    margin: 0 0 22px;
    opacity: 0;
    animation: fade-up 0.8s var(--ease-out) 0.15s forwards;
  }
  .hero__title {
    font-size: clamp(2.3rem, 1.3rem + 4.6vw, 4.4rem);
    line-height: 1.22;
    letter-spacing: 0.03em;
    margin: 0;
    color: var(--brown-deep);
    font-weight: 600;
  }
  .hero__sub {
    font-style: italic;
    font-size: clamp(1.05rem, 0.9rem + 0.8vw, 1.5rem);
    color: var(--terracotta-deep);
    margin: 20px 0 0;
    opacity: 0;
    animation: fade-up 0.8s var(--ease-out) 0.5s forwards;
  }
  .hero__lead {
    color: var(--ink-soft);
    font-size: 1.05rem;
    margin: 26px 0 34px;
    opacity: 0;
    animation: fade-up 0.8s var(--ease-out) 0.65s forwards;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px 28px;
    opacity: 0;
    animation: fade-up 0.8s var(--ease-out) 0.8s forwards;
  }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: none; }
  }

  /* ---- メディア ---- */
  .hero__media {
    position: relative;
    opacity: 0;
    animation: fade-in 1.1s var(--ease-out) 0.4s forwards;
    will-change: transform;
  }
  @keyframes fade-in {
    to { opacity: 1; }
  }
  .hero__halo {
    position: absolute;
    inset: -10%;
    z-index: -1;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--gold) 50%, transparent),
      transparent 60%
    );
    filter: blur(26px);
    animation: float-soft 7s ease-in-out infinite;
  }
  /* オフセットした罫線フレーム（編集的） */
  .hero__frame {
    position: absolute;
    inset: 16px -16px -16px 16px;
    border: 1px solid color-mix(in srgb, var(--brown) 45%, transparent);
    border-radius: var(--radius-lg);
    z-index: -1;
  }
  .hero__img,
  .hero__ph {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    transition: transform 0.6s var(--ease-out);
  }
  .hero__ph {
    display: grid;
    place-content: center;
  }
  .hero__media:hover .hero__img {
    transform: scale(1.015) rotate(-0.4deg);
  }
  .hero__caption {
    position: absolute;
    bottom: 18px;
    left: 18px;
    font-style: italic;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    color: var(--white);
    background: color-mix(in srgb, var(--brown-deep) 78%, transparent);
    backdrop-filter: blur(4px);
    padding: 6px 14px;
    border-radius: 999px;
  }

  /* ---- スクロールキュー ---- */
  .hero__scroll {
    position: absolute;
    bottom: 26px;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    font-style: italic;
    font-size: 0.8rem;
    letter-spacing: 0.16em;
    color: var(--ink-soft);
  }
  .hero__scroll:hover { text-decoration: none; }
  .hero__scroll-line {
    width: 1px;
    height: 46px;
    background: linear-gradient(var(--brown), transparent);
    position: relative;
    overflow: hidden;
  }
  .hero__scroll-line::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 40%;
    background: var(--terracotta);
    animation: scroll-cue 1.8s var(--ease-out) infinite;
  }
  @keyframes scroll-cue {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(260%); }
  }
  @media (max-width: 920px) {
    .hero__scroll { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__kicker,
    .hero__sub,
    .hero__lead,
    .hero__actions,
    .hero__media {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
