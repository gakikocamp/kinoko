---
import type { StoreInfo } from "../lib/site";
import { withBase } from "../lib/url";

interface Props {
  store: StoreInfo;
}
const { store } = Astro.props;
---

<section class="hero">
  <!-- 動く光の背景 -->
  <div class="hero__aurora" aria-hidden="true">
    <span class="blob blob--teal"></span>
    <span class="blob blob--gold"></span>
    <span class="blob blob--coral"></span>
  </div>
  <!-- 漂う輝き（天使の光） -->
  <div class="hero__sparkles" aria-hidden="true">
    <span style="--x:12%; --y:24%; --d:0s; --s:1"></span>
    <span style="--x:78%; --y:18%; --d:1.1s; --s:0.7"></span>
    <span style="--x:64%; --y:62%; --d:2s; --s:1.2"></span>
    <span style="--x:30%; --y:74%; --d:0.6s; --s:0.8"></span>
    <span style="--x:88%; --y:48%; --d:1.6s; --s:0.9"></span>
  </div>

  <div class="container hero__inner">
    <div class="hero__copy">
      <span class="eyebrow hero__eyebrow">Anela Cafe Fukuoka ・ {store.shortName}</span>
      <h1 class="hero__title">
        <span class="text-gradient">{store.tagline}</span>
      </h1>
      <p class="hero__lead">
        コーヒーと、保護犬と、やさしい時間。<br />
        アネラカフェ{store.shortName}へようこそ。
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href={withBase("/access")}>アクセス・営業時間</a>
        <a class="btn btn--ghost" href={store.instagram} target="_blank" rel="noopener">
          Instagramを見る
        </a>
      </div>
    </div>
    <div class="hero__media">
      <span class="hero__halo" aria-hidden="true"></span>
      {
        store.heroImage ? (
          <img
            class="hero__img"
            src={store.heroImage}
            alt={`アネラカフェ${store.shortName}の店内・わんこの様子`}
            width="640"
            height="640"
          />
        ) : (
          <div class="ph ph--square hero__ph" role="img" aria-label="店内・保護犬の写真（準備中）">
            店内・わんこの写真
          </div>
        )
      }
    </div>
  </div>

  <!-- 下端の波 -->
  <div class="wave-divider hero__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none">
      <path
        d="M0,32 C240,72 480,8 720,28 C960,48 1200,72 1440,36 L1440,60 L0,60 Z"
        fill="var(--cream)"></path>
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: clamp(56px, 8vw, 96px) 0;
    background:
      radial-gradient(
        90% 120% at 85% 0%,
        color-mix(in srgb, var(--brown) 18%, var(--cream)) 0%,
        var(--cream) 55%
      );
  }

  /* ---- 動く光のブロブ ---- */
  .hero__aurora {
    position: absolute;
    inset: -20% -10% 0;
    z-index: -2;
    filter: blur(60px);
    opacity: 0.7;
  }
  .blob {
    position: absolute;
    width: 46vw;
    max-width: 560px;
    aspect-ratio: 1;
    border-radius: 50%;
    mix-blend-mode: multiply;
  }
  .blob--teal {
    top: -8%;
    right: -4%;
    background: radial-gradient(circle at 30% 30%, var(--brown), transparent 65%);
    animation: drift1 18s ease-in-out infinite;
  }
  .blob--gold {
    top: 18%;
    left: -6%;
    background: radial-gradient(circle at 30% 30%, var(--gold), transparent 65%);
    animation: drift2 22s ease-in-out infinite;
  }
  .blob--coral {
    bottom: -16%;
    right: 22%;
    width: 34vw;
    background: radial-gradient(circle at 30% 30%, var(--terracotta), transparent 65%);
    animation: drift3 26s ease-in-out infinite;
  }
  @keyframes drift1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-6%, 8%) scale(1.12); }
  }
  @keyframes drift2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(8%, -6%) scale(1.08); }
  }
  @keyframes drift3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-10%, -4%) scale(1.15); }
  }

  /* ---- 漂う輝き ---- */
  .hero__sparkles {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }
  .hero__sparkles span {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: calc(7px * var(--s));
    height: calc(7px * var(--s));
    background: radial-gradient(circle, var(--white), color-mix(in srgb, var(--gold) 70%, transparent));
    border-radius: 50%;
    box-shadow: 0 0 10px 2px color-mix(in srgb, var(--gold) 60%, transparent);
    animation: sparkle 4s var(--ease-out) infinite;
    animation-delay: var(--d);
  }
  @keyframes sparkle {
    0%, 100% { opacity: 0; transform: scale(0.4) translateY(0); }
    40% { opacity: 1; transform: scale(1) translateY(-6px); }
    70% { opacity: 0.5; transform: scale(0.8) translateY(-10px); }
  }

  .hero__inner {
    position: relative;
    display: grid;
    gap: 32px;
    align-items: center;
    padding-bottom: clamp(40px, 7vw, 80px);
  }
  @media (min-width: 860px) {
    .hero__inner {
      grid-template-columns: 1.08fr 0.92fr;
    }
  }

  /* ---- 登場アニメーション ---- */
  .hero__eyebrow,
  .hero__title,
  .hero__lead,
  .hero__actions {
    opacity: 0;
    transform: translateY(20px);
    animation: hero-in 0.8s var(--ease-out) forwards;
  }
  .hero__eyebrow { animation-delay: 0.05s; }
  .hero__title { animation-delay: 0.18s; }
  .hero__lead { animation-delay: 0.32s; }
  .hero__actions { animation-delay: 0.46s; }
  @keyframes hero-in {
    to { opacity: 1; transform: none; }
  }

  .hero__title {
    font-size: clamp(2rem, 1.2rem + 3.2vw, 3.2rem);
    line-height: 1.25;
    margin: 16px 0 18px;
  }
  .hero__lead {
    color: var(--ink-soft);
    font-size: 1.08rem;
    margin: 0 0 30px;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  /* ---- メディア（画像＋光輪） ---- */
  .hero__media {
    position: relative;
    opacity: 0;
    transform: translateY(24px) scale(0.96);
    animation: hero-media-in 1s var(--ease-out) 0.3s forwards;
  }
  @keyframes hero-media-in {
    to { opacity: 1; transform: none; }
  }
  .hero__halo {
    position: absolute;
    inset: -8% -8% auto -8%;
    aspect-ratio: 1;
    z-index: -1;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--gold) 55%, transparent),
      transparent 62%
    );
    filter: blur(22px);
    animation: float-soft 6s ease-in-out infinite;
  }
  .hero__img,
  .hero__ph {
    position: relative;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    transition: transform 0.5s var(--ease-out);
  }
  .hero__media:hover .hero__img {
    transform: translateY(-6px) rotate(-0.6deg);
  }

  .hero__wave {
    position: relative;
    margin-top: -1px;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__eyebrow,
    .hero__title,
    .hero__lead,
    .hero__actions,
    .hero__media {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
