---
import type { StoreInfo } from "../lib/site";
import { withBase } from "../lib/url";

interface Props {
  store: StoreInfo;
}
const { store } = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      <span class="eyebrow">Anela Cafe Fukuoka ・ {store.shortName}</span>
      <h1 class="hero__title">{store.tagline}</h1>
      <p class="hero__lead">
        コーヒーと、保護犬と、やさしい時間。<br />
        アネラカフェ{store.shortName}へようこそ。
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href={withBase("/access")}>アクセス・営業時間</a>
        <a class="btn btn--ghost" href={store.instagram} target="_blank" rel="noopener">
          Instagramを見る
        </a>
      </div>
    </div>
    <div class="hero__media">
      {
        store.heroImage ? (
          <img
            class="hero__img"
            src={store.heroImage}
            alt={`アネラカフェ${store.shortName}の店内・わんこの様子`}
            width="640"
            height="640"
          />
        ) : (
          <div class="ph ph--square" role="img" aria-label="店内・保護犬の写真（準備中）">
            店内・わんこの写真
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .hero {
    background:
      radial-gradient(
        90% 120% at 85% 0%,
        color-mix(in srgb, var(--brown) 22%, var(--cream)) 0%,
        var(--cream) 55%
      ),
      linear-gradient(180deg, color-mix(in srgb, var(--gold) 10%, transparent), transparent 40%);
    padding-block: 64px;
  }
  .hero__inner {
    display: grid;
    gap: 32px;
    align-items: center;
  }
  @media (min-width: 860px) {
    .hero__inner {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }
  .hero__title {
    font-size: clamp(1.8rem, 1.2rem + 2.6vw, 2.8rem);
    margin: 14px 0 16px;
  }
  .hero__lead {
    color: var(--ink-soft);
    font-size: 1.05rem;
    margin: 0 0 28px;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .hero__media .ph {
    border-radius: var(--radius-lg);
  }
  .hero__img {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }
</style>
