---
import type { StoreInfo } from "../lib/site";
import { ORG } from "../lib/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { withBase } from "../lib/url";
import { Content as AdoptionContent } from "../content/adoption.md";

interface Props {
  store: StoreInfo;
}
const { store } = Astro.props;
---

<BaseLayout store={store} path="/adoption" title="里親募集">
  <PageHeader
    kicker="Adoption"
    title="里親募集"
    lead="新しい家族を待つ保護犬たち。いま出会える子は Instagram で発信しています。"
  />
  <section class="section">
    <div class="container">
      <div style="text-align:center;margin-bottom:32px">
        <a class="btn btn--primary" href={ORG.adoptionInstagram} target="_blank" rel="noopener">
          いま出会える子をInstagramで見る
        </a>
      </div>

      <article class="prose">
        <AdoptionContent />
      </article>

      <div style="margin-top:40px;max-width:720px;margin-inline:auto">
        <div class="card" style="padding:24px;text-align:center">
          <p style="margin-top:0">
            気になる子がいたら、まずは{store.shortName}までお気軽にご相談ください。
          </p>
          <a class="btn btn--ghost" href={withBase("/contact")}>お問い合わせ</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
