---
import type { StoreInfo } from "../lib/site";
import BaseLayout from "../layouts/BaseLayout.astro";

interface Props {
  store: StoreInfo;
}
const { store } = Astro.props;

// メニューはプレースホルダー。確定後に内容・写真を差し替える。
const menus = [
  {
    category: "コーヒー / ドリンク",
    items: [
      { name: "ブレンドコーヒー", price: "¥500" },
      { name: "カフェラテ", price: "¥550" },
      { name: "季節のドリンク", price: "¥600〜" },
      { name: "紅茶 / ハーブティー", price: "¥500" },
    ],
  },
  {
    category: "フード / スイーツ",
    items: [
      { name: "本日のケーキ", price: "¥450〜" },
      { name: "トースト各種", price: "¥400〜" },
      { name: "ランチプレート", price: "¥1,000" },
      { name: "焼き菓子", price: "¥300〜" },
    ],
  },
];
---

<BaseLayout store={store} path="/menu" title="メニュー">
  <section class="section">
    <div class="container">
      <span class="eyebrow" style="display:block;text-align:center">Menu</span>
      <h1 class="section-title">メニュー</h1>
      <p class="section-lead">
        ※ 内容・価格はイメージです。実際のメニューが決まり次第更新します。<br />
        季節のメニューは note・Instagram でもご紹介しています。
      </p>

      <div class="grid grid--2">
        {
          menus.map((m) => (
            <div class="card menu-card">
              <div class="ph ph--wide" role="img" aria-label="メニュー写真（準備中）">
                {m.category}の写真
              </div>
              <div class="menu-card__body">
                <h2 class="menu-card__cat">{m.category}</h2>
                <ul class="menu-list">
                  {m.items.map((i) => (
                    <li class="menu-list__row">
                      <span>{i.name}</span>
                      <span class="menu-list__price">{i.price}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .menu-card__body {
    padding: 20px 24px 24px;
  }
  .menu-card__cat {
    font-size: 1.1rem;
    margin: 0 0 12px;
  }
  .menu-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .menu-list__row {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px dashed var(--line);
  }
  .menu-list__price {
    color: var(--ink-soft);
    font-weight: 600;
    white-space: nowrap;
  }
</style>
