---
import type { StoreInfo } from "../lib/site";
import { ORG } from "../lib/site";
import { fetchNoteNews } from "../lib/note-rss";
import { withBase } from "../lib/url";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import NewsList from "../components/NewsList.astro";
import InstagramEmbed from "../components/InstagramEmbed.astro";

interface Props {
  store: StoreInfo;
}
const { store } = Astro.props;
const news = await fetchNoteNews(ORG.noteAccount, 3);

const features = [
  {
    href: "/adoption",
    title: "里親募集",
    text: "新しい家族を待つ保護犬たち。最新の子はInstagramで発信しています。",
    accent: "var(--green)",
  },
  {
    href: "/welfare",
    title: "就労支援（B型）",
    text: "自分のペースで働ける場所。見学・ご相談はいつでも歓迎です。",
    accent: "var(--brown)",
  },
  {
    href: "/recruit",
    title: "スタッフ募集",
    text: "カフェと福祉、両方を大切にする仲間を募集しています。",
    accent: "var(--gold)",
  },
];
---

<BaseLayout store={store} path="/">
  <Hero store={store} />

  <!-- コンセプト -->
  <section class="section">
    <div class="container split">
      <div>
        <span class="eyebrow">Concept</span>
        <h2 class="section-title" style="text-align:left">
          コーヒーと、保護犬と、<br />まちのやさしい居場所
        </h2>
        <p>
          アネラカフェ{store.shortName}は、おいしいコーヒーを楽しめるカフェであると同時に、
          保護犬の里親探しや、就労継続支援B型の場としても地域に開かれたお店です。
        </p>
        <p>
          ふらっと立ち寄って、ゆっくり過ごす。そんな何気ない時間が、
          人にも動物にもやさしい循環につながればと願っています。
        </p>
      </div>
      <div class="ph ph--wide" role="img" aria-label="カフェの雰囲気（写真準備中）">
        カフェの雰囲気の写真
      </div>
    </div>
  </section>

  {/* ご利用案内（ドリンクバー形式） */}
  <section class="section bg-deep">
    <div class="container" style="max-width:760px">
      <span class="eyebrow" style="display:block;text-align:center">Drink Bar</span>
      <h2 class="section-title">ご利用案内</h2>
      <p class="section-lead">{ORG.drinkBar.lead}</p>
      <div class="card" style="padding:24px">
        <ul class="pricing">
          {
            ORG.drinkBar.items.map((i) => (
              <li class="pricing__row">
                <span>{i.label}</span>
                <span class="pricing__price">{i.value}</span>
              </li>
            ))
          }
        </ul>
        <p style="color:var(--ink-soft);font-size:0.85rem;margin:14px 0 0">
          {ORG.drinkBar.note}
        </p>
      </div>
      <p style="text-align:center;margin-top:24px">
        <a class="btn btn--ghost" href={withBase("/access")}>アクセス・営業時間を見る</a>
      </p>
    </div>
  </section>

  {/* Instagram セクション：投稿埋め込み → 画像ギャラリー → フォロー導線 の優先順で表示 */}
  <section class="section section--tight">
    <div class="container">
      <span class="eyebrow" style="display:block;text-align:center">Instagram</span>
      <h2 class="section-title">日々の様子</h2>
      <p class="section-lead">カフェやわんこの最新の様子は Instagram で発信中。</p>

      {
        store.instagramPosts && store.instagramPosts.length > 0 ? (
          <InstagramEmbed posts={store.instagramPosts} />
        ) : store.gallery && store.gallery.length > 0 ? (
          <div class="gallery">
            {store.gallery.map((g) => (
              <img class="gallery__img" src={g.src} alt={g.alt} loading="lazy" />
            ))}
          </div>
        ) : (
          <div class="card" style="padding:28px;text-align:center;max-width:560px;margin-inline:auto">
            <p style="margin-top:0">
              写真は Instagram で随時更新しています。フォローして最新の様子をチェック！
            </p>
            <a class="btn btn--primary" href={store.instagram} target="_blank" rel="noopener">
              Instagramを見る
            </a>
          </div>
        )
      }

      {
        Boolean(store.instagramPosts?.length || store.gallery?.length) && (
          <p style="text-align:center; margin-top:24px">
            <a class="btn btn--ghost" href={store.instagram} target="_blank" rel="noopener">
              もっと見る（Instagram）
            </a>
          </p>
        )
      }
    </div>
  </section>

  <!-- 取り組み -->
  <section class="section bg-deep">
    <div class="container">
      <h2 class="section-title">アネラカフェの3つの取り組み</h2>
      <p class="section-lead">カフェを入り口に、できることを少しずつ。</p>
      <div class="grid grid--3">
        {
          features.map((f) => (
            <a class="feature card" href={withBase(f.href)} style={`--accent:${f.accent}`}>
              <div class="feature__body">
                <h3 class="feature__title">{f.title}</h3>
                <p class="feature__text">{f.text}</p>
                <span class="feature__more">くわしく見る →</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- お知らせ -->
  <section class="section">
    <div class="container" style="max-width:760px">
      <h2 class="section-title">お知らせ</h2>
      <p class="section-lead">最新情報は note で発信しています。</p>
      <NewsList items={news} emptyHint={true} />
      <p style="text-align:center; margin-top:24px">
        <a class="btn btn--ghost" href={withBase("/news")}>お知らせ一覧へ</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .feature {
    display: block;
    padding: 0;
    border-top: 4px solid var(--accent, var(--brown));
  }
  .feature:hover {
    text-decoration: none;
    transform: translateY(-3px);
    transition: transform 0.15s ease;
  }
  .feature__body {
    padding: 24px;
  }
  .feature__title {
    margin: 0 0 8px;
    font-size: 1.2rem;
  }
  .feature__text {
    color: var(--ink-soft);
    margin: 0 0 12px;
    font-size: 0.95rem;
  }
  .feature__more {
    font-weight: 700;
    color: var(--terracotta-deep);
    font-size: 0.9rem;
  }

  .pricing {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .pricing__row {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px dashed var(--line);
  }
  .pricing__price {
    color: var(--ink-soft);
    font-weight: 600;
    white-space: nowrap;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  @media (min-width: 640px) {
    .gallery {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .gallery__img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radius);
  }
</style>
