---
import type { StoreInfo } from "../lib/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactMethods from "../components/ContactMethods.astro";
import { Content as WelfareContent } from "../content/welfare.md";

interface Props {
  store: StoreInfo;
}
const { store } = Astro.props;
---

<BaseLayout store={store} path="/welfare" title="就労継続支援B型 利用者募集">
  <section class="section">
    <div class="container">
      <span class="eyebrow" style="display:block;text-align:center">Welfare</span>
      <h1 class="section-title">就労継続支援B型<br />利用者募集</h1>

      <article class="prose">
        <WelfareContent />
      </article>

      <div style="margin-top:40px;max-width:720px;margin-inline:auto">
        <ContactMethods
          store={store}
          heading="見学・ご相談はこちら"
          mailSubject="就労支援B型の見学希望"
        />
      </div>
    </div>
  </section>
</BaseLayout>
