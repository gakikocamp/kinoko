#!/usr/bin/env bash
# ============================================================
#  pre-commit SECRET GUARD（ツール非依存）
# ------------------------------------------------------------
#  コミットしようとしている内容に「秘密情報」や「個人情報・名簿」が
#  あればコミットを止めます。Antigravity / Claude / ターミナル 共通。
#
#  有効化: `bash setup-guardrails.sh`（core.hooksPath .githooks）
# ============================================================
# core.quotePath=false で日本語ファイル名もそのまま扱う
staged="$(git -c core.quotePath=false diff --cached --name-only --diff-filter=ACM)"
[ -z "$staged" ] && exit 0

fail=0
note() { echo "🛑 SECRET GUARD: $1" >&2; fail=1; }

# 1) .env 系ファイル自体をコミットしようとしていないか（.env.example は除外）
envfiles="$(printf '%s\n' "$staged" | grep -Ei '(^|/)\.env($|\.)' | grep -viE '\.env\.example$')"
if [ -n "$envfiles" ]; then
  note ".env 系ファイルをコミットしようとしています（秘密情報の恐れ）:"
  printf '%s\n' "$envfiles" | sed 's/^/     - /' >&2
fi

# 2) 個人情報・名簿らしき「ファイル」をコミットしようとしていないか
#    （顧客名簿・会員リスト等は原則リポジトリに入れない運用）
piifiles="$(printf '%s\n' "$staged" | grep -Ei '\.(csv|tsv|xlsx?|numbers|vcf|ics)$|名簿|顧客|個人情報|会員|customer|roster|personal[_-]?info|members?[_-]?list')"
if [ -n "$piifiles" ]; then
  note "個人情報・名簿らしきファイルをコミットしようとしています（リポジトリに入れない運用）:"
  printf '%s\n' "$piifiles" | sed 's/^/     - /' >&2
  echo "     ※ お客様の名簿・会員リスト等はリポジトリに置かないでください。" >&2
  echo "       本当にサイトに必要なデータファイルだけ、内容を確認のうえ許可してください。" >&2
fi

# 3) 追加された行の中身をスキャン
added="$(git diff --cached -U0 --diff-filter=ACM | grep -E '^\+' | grep -vE '^\+\+\+')"

check() { # $1=正規表現 $2=ラベル
  if printf '%s\n' "$added" | grep -Eiq "$1"; then
    note "$2 らしき文字列が含まれています。"
  fi
}
check '-----BEGIN [A-Z ]*PRIVATE KEY-----'                          "秘密鍵(PRIVATE KEY)"
check 'AKIA[0-9A-Z]{16}'                                            "AWSアクセスキー"
check 'AIza[0-9A-Za-z_-]{35}'                                       "Google APIキー"
check 'gh[pousr]_[0-9A-Za-z]{20,}'                                  "GitHubトークン"
check 'xox[baprs]-[0-9A-Za-z-]{10,}'                                "Slackトークン"
check '(password|passwd|secret|api[_-]?key|access[_-]?token|auth[_-]?token)["'"'"' ]*[:=]["'"'"' ]*["'"'"'][^"'"'"']{8,}' "パスワード/トークンの直書き"

if [ "$fail" -ne 0 ]; then
  echo "" >&2
  echo "  → 秘密情報はコミットしないでください。値は .env（コミット対象外）に置くか、削除を。" >&2
  echo "  → 誤検知で本当に問題ない時のみ、人間が確認のうえ 'git commit --no-verify' で回避できます。" >&2
  exit 1
fi
exit 0
